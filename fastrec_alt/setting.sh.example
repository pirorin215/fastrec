#!/bin/bash
# fastrec_alt 設定ファイル
# 各スクリプトから source コマンドで読み込まれます

#=============================================================================
# シリアルポート設定（必須）
#=============================================================================
# ESP32 デバイスのシリアルポートを指定してください
# 自動検出を廃止し、明示的に指定することで、意図しないデバイスへの
# ファームウェア書き込みやログ出力を防ぐためです
#
# 設定例:
#   ESP_PORT="/dev/cu.usbmodem21201"
#   ESP_PORT="/dev/cu.usbmodem1301"
#   ESP_PORT="/dev/tty.usbmodem21201"
#   ESP_PORT="/dev/ttyUSB0"
#
# 未設定の場合はエラーで終了します
#=============================================================================

ESP_PORT="/dev/cu.usbmodemXXXX"

#=============================================================================
# その他の設定（将来の拡張用）
#=============================================================================
# ここに他の設定変数を追加できます
